# ── Polymarket ────────────────────────────────────────────────────────────────
# Your Ethereum wallet private key (0x...)
POLYMARKET_PRIVATE_KEY=0x

# Optional — derived from private key via scripts/setup-polymarket.ts
POLYMARKET_API_KEY=
POLYMARKET_SECRET=
POLYMARKET_PASSPHRASE=

# ── Kalshi ────────────────────────────────────────────────────────────────────
# API Key ID from kalshi.com → Settings → API Keys
KALSHI_API_KEY_ID=

# RSA private key — must be wrapped in double quotes for multiline parsing
KALSHI_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
YOUR_KEY_HERE
-----END RSA PRIVATE KEY-----"

# ── AI / LLM ──────────────────────────────────────────────────────────────────
# Single key for all 5 models (Claude, GPT-4o, Gemini, DeepSeek, Grok)
# Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string — create DB with: createdb wall_street_wolf
DATABASE_URL=postgresql://YOUR_USER:YOUR_PASSWORD@localhost:5432/wall_street_wolf

# ── Optional data sources ─────────────────────────────────────────────────────
# NewsAPI — https://newsapi.org (free tier: 100 req/day)
NEWS_API_KEY=

# FRED (Federal Reserve data) — https://fred.stlouisfed.org/docs/api/api_key.html (free)
FRED_API_KEY=

# ── Trading config ────────────────────────────────────────────────────────────
# Set to true for paper trading (relaxed filters, no real money)
DEMO_MODE=true

# Starting bankroll in USD
INITIAL_BANKROLL=10000

# Minimum edge to trade (0.04 = 4%)
MIN_EDGE=0.04

# Max single position size in USD
MAX_POSITION_SIZE_USD=500

# Max total exposure across all positions
MAX_TOTAL_EXPOSURE_USD=5000

# Max daily loss before bot stops for the day
MAX_DAILY_LOSS_USD=750

# Max drawdown before all trading halts (0.08 = 8%)
MAX_DRAWDOWN_PCT=0.08

# Max concurrent open positions
MAX_CONCURRENT_POSITIONS=15

# Fractional Kelly multiplier (0.25 = quarter-Kelly, recommended)
KELLY_FRACTION=0.25

# Scan interval in milliseconds (900000 = 15 min)
SCAN_INTERVAL_MS=900000

# Max daily spend on AI API calls
MAX_DAILY_API_COST_USD=50

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
TRADE_LOG_PATH=./data/trades.jsonl
FAILURE_LOG_PATH=./data/failures.jsonl
PREDICTION_LOG_PATH=./data/predictions.jsonl
