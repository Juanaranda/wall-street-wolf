{
  "name": "wall-street-wolf",
  "version": "1.0.0",
  "description": "AI-powered prediction market trading bot using Claude Skills",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "dashboard": "ts-node src/dashboard/server.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@polymarket/clob-client": "^5.8.1",
    "@types/pg": "^8.20.0",
    "axios": "^1.7.9",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.7",
    "ethers": "^6.13.4",
    "express": "^5.2.1",
    "node-schedule": "^2.1.1",
    "openai": "^4.77.0",
    "pg": "^8.20.0",
    "sentiment": "^5.0.2",
    "uuid": "^11.0.5",
    "winston": "^3.17.0",
    "ws": "^8.18.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/tests"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^@shared/(.*)$": "<rootDir>/src/shared/$1",
      "^@polymarket/clob-client$": "<rootDir>/tests/__mocks__/@polymarket/clob-client.ts"
    }
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.10",
    "@types/node-schedule": "^2.1.7",
    "@types/sentiment": "^5.0.4",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
